# Copia este archivo como .env.sentry.staging (ignorado por git)
# y completa los valores reales para staging.

APP_ENV=staging
APP_DEBUG=false
# Debe ser URL HTTPS real de staging (no localhost) para cierre T1.4.
APP_URL=https://tick-system-remoto-main-j5ip7y.free.laravel.cloud/
TRUSTED_PROXIES=*

SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

SECURITY_HEADERS_CSP_MODE=report-only
SECURITY_HEADERS_ENABLE_HSTS=true
SECURITY_HEADERS_FORCE_HSTS=false
SECURITY_HEADERS_HSTS_MAX_AGE=31536000
SECURITY_HEADERS_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HEADERS_HSTS_PRELOAD=false

SENTRY_LARAVEL_DSN=replace_with_staging_dsn
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=staging-2026-04-18
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.10
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENABLE_LOGS=false
