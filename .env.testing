# ============================================================
# .env.testing — Solo para GitHub Actions CI
# NO commitear credenciales reales aquí
# ============================================================

APP_NAME="Ticketing System CI"
APP_ENV=testing
APP_KEY=                          # El workflow corre: php artisan key:generate --env=testing
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4                   # Más rápido en tests

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                   # Solo errores en CI, menos ruido

# Sentry desactivado en CI
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=testing
SENTRY_SAMPLE_RATE=0.0
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENABLE_LOGS=false

TRUSTED_PROXIES=*

# Security headers (mismos valores, no afectan tests)
SECURITY_HEADERS_FRAME_OPTIONS=SAMEORIGIN
SECURITY_HEADERS_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_HEADERS_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_HEADERS_PERMISSIONS_POLICY="camera=(), geolocation=(), microphone=()"
SECURITY_HEADERS_COOP=same-origin
SECURITY_HEADERS_CORP=same-origin
SECURITY_HEADERS_CSP_MODE=report-only
SECURITY_HEADERS_CSP="default-src 'self'"
SECURITY_HEADERS_ENABLE_HSTS=false
SECURITY_HEADERS_FORCE_HSTS=false
SECURITY_HEADERS_HSTS_MAX_AGE=0
SECURITY_HEADERS_HSTS_INCLUDE_SUBDOMAINS=false
SECURITY_HEADERS_HSTS_PRELOAD=false

# ── Base de datos ─────────────────────────────────────────
# Apunta al servicio PostgreSQL que levanta el workflow
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=testing
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable                # Sin SSL en el contenedor local de CI
DB_EMULATE_PREPARES=true
ALLOW_SQLITE_IN_PRODUCTION=false

# ── Sesión / Cache / Queue ────────────────────────────────
# Sin Redis en CI — todo en memoria/array
SESSION_DRIVER=array
SESSION_CONNECTION=null
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync             # Jobs se ejecutan de forma síncrona en tests

CACHE_STORE=array                 # Cache en memoria, sin Redis

# Redis desactivado (no hay servidor Redis en CI)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────
MAIL_MAILER=array                 # Emails capturados en memoria, no se envían
MAIL_FROM_ADDRESS="ci@ticketing.test"
MAIL_FROM_NAME="Ticketing CI"

# ── Supabase (valores falsos — tests usan la DB local) ────
SUPABASE_URL=http://localhost
SUPABASE_SERVICE_ROLE_KEY=fake-service-role-key-for-testing
SUPABASE_ROLE_SYNC_ENABLED=false
SUPABASE_TIMEOUT=10
SUPABASE_AUTH_ADMIN_USERS_ENDPOINT=/auth/v1/admin/users

SUPABASE_STORAGE_API_BASE_URL=http://localhost
SUPABASE_STORAGE_PUBLIC_BASE_URL=http://localhost
SUPABASE_STORAGE_SERVICE_KEY=fake-service-role-key-for-testing
SUPABASE_STORAGE_TIMEOUT=10
SUPABASE_STORAGE_USE_LOCAL_DISK_FOR_TESTING=true  # Usa disco local en vez de Supabase
SUPABASE_STORAGE_TESTING_DISK=public

SUPABASE_BUCKET_CATEGORIES=TicketCategoria
SUPABASE_BUCKET_LOCATIONS=TablaLocations
SUPABASE_BUCKET_TICKETS=TableTicket
SUPABASE_BUCKET_USERS=TablaUsers

SUPABASE_PREFIX_CATEGORIES=categories/icons
SUPABASE_PREFIX_LOCATIONS=locations/qr-codes
SUPABASE_PREFIX_TICKETS=tickets/media
SUPABASE_PREFIX_USERS=users/avatars

# ── Feature flags ─────────────────────────────────────────
FEATURE_QR_ENABLED=false
DEDUP_WINDOW_HOURS=24

VITE_APP_NAME="Ticketing CI"
